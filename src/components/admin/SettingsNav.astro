---
const current = Astro.url.pathname;

const links = [
  { href: '/admin/settings', label: 'Overview', match: (p: string) => p === '/admin/settings' || p === '/admin/settings/' },
  { href: '/admin/settings/users', label: 'Users', match: (p: string) => p.startsWith('/admin/settings/users') },
];
---

<nav class="settings-nav" aria-label="Settings sections">
  <ul>
    {
      links.map((l) => (
        <li>
          <a href={l.href} class:list={[{ active: l.match(current) }]}>
            {l.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .settings-nav {
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.5rem;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
  }
  a {
    display: inline-block;
    padding: 0.55rem 0.9rem;
    color: var(--muted);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    font-weight: 500;
  }
  a:hover {
    color: var(--text);
  }
  a.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
</style>
