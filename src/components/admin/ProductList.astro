---
import type { ProductStatus } from '~/lib/supabase/types';

interface ListItem {
  id: string;
  slug: string;
  piece_id: string | null;
  title: string;
  price_cents: number;
  status: ProductStatus;
  featured: boolean;
  created_at: string;
  primary_image_url: string | null;
}

interface Props {
  products: ListItem[];
}
const { products } = Astro.props;

function formatPrice(cents: number) {
  return `$${(cents / 100).toFixed(2)}`;
}
function formatDate(iso: string) {
  try {
    return new Date(iso).toLocaleDateString();
  } catch {
    return iso;
  }
}
---

{
  products.length === 0 ? (
    <div class="empty panel">No products yet. Create your first one.</div>
  ) : (
    <div class="list">
      {products.map((p) => (
        <a class="row" href={`/admin/products/${p.id}/edit`}>
          <div class="thumb">
            {p.primary_image_url ? (
              <img src={p.primary_image_url} alt="" loading="lazy" />
            ) : (
              <div class="thumb-empty">no image</div>
            )}
          </div>
          <div class="meta">
            <div class="title">
              {p.piece_id && <span class="piece-id muted">{p.piece_id}</span>}
              <span>{p.title}</span>
              {p.featured && <span class="featured-badge" title="Featured on homepage">★</span>}
            </div>
            <div class="sub muted">
              /{p.slug} · {formatDate(p.created_at)}
            </div>
          </div>
          <div class="price">{formatPrice(p.price_cents)}</div>
          <div class="status">
            <span class={`badge badge-${p.status}`}>{p.status}</span>
          </div>
        </a>
      ))}
    </div>
  )
}

<style>
  .empty {
    text-align: center;
    color: var(--muted);
    padding: 2rem;
  }
  .list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .row {
    display: grid;
    grid-template-columns: 64px 1fr auto auto;
    gap: 0.9rem;
    align-items: center;
    padding: 0.65rem 0.85rem;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, background 0.15s;
  }
  .row:hover {
    border-color: var(--accent);
    background: #fbfaf6;
  }
  .thumb {
    width: 64px;
    height: 64px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--muted-bg);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .thumb-empty {
    font-size: 0.7rem;
    color: var(--muted);
  }
  .title {
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
  }
  .piece-id {
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    font-weight: 600;
    text-transform: uppercase;
  }
  .featured-badge {
    color: var(--amber);
    font-size: 0.95rem;
    line-height: 1;
  }
  .sub {
    font-size: 0.85rem;
  }
  .price {
    font-variant-numeric: tabular-nums;
    font-weight: 600;
  }
  @media (max-width: 600px) {
    .row {
      grid-template-columns: 48px 1fr auto;
      gap: 0.6rem;
    }
    .thumb {
      width: 48px;
      height: 48px;
    }
    .price {
      grid-column: 2;
      grid-row: 2;
      font-size: 0.9rem;
    }
    .status {
      grid-column: 3;
      grid-row: 1 / span 2;
      align-self: center;
    }
  }
</style>
