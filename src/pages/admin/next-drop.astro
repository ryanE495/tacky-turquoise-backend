---
import AdminLayout from '~/layouts/AdminLayout.astro';
import NextDropForm from '~/components/admin/NextDropForm.astro';
import { createSupabaseAdminClient } from '~/lib/supabase/admin';

export const prerender = false;

const supabase = createSupabaseAdminClient();
const { data: settings, error } = await supabase
  .from('drop_settings')
  .select('*')
  .eq('id', 1)
  .maybeSingle();
---

<AdminLayout title="Next drop">
  <div class="page-header">
    <div>
      <h1>Next drop</h1>
      <div class="muted">Drives the countdown banner on the storefront.</div>
    </div>
    <a class="btn" href="/api/next-drop" target="_blank" rel="noopener">View public JSON</a>
  </div>

  {error && <div class="flash flash-error">{error.message}</div>}

  {
    settings ? (
      <div class="panel">
        <NextDropForm settings={settings} />
      </div>
    ) : (
      <div class="panel">
        <p class="muted">Drop settings row not found. Run the latest migration.</p>
      </div>
    )
  }
</AdminLayout>
