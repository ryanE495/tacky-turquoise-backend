---
// Public route. Handles invite + recovery callbacks from Supabase emails.
// Supabase adds tokens to the URL hash; the browser client auto-detects
// and creates a session, then we call updateUser to set a new password.
export const prerender = false;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Set password · Admin</title>
    <style>
      body {
        margin: 0;
        background: #f7f6f2;
        color: #1a1a1a;
        font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 1rem;
      }
      .panel {
        background: #fff;
        border: 1px solid #e2ded4;
        border-radius: 8px;
        padding: 1.5rem;
        max-width: 420px;
        width: 100%;
      }
      h1 { margin: 0 0 0.25rem; font-size: 1.4rem; }
      p.muted { color: #6b6b6b; }
      label { display: block; margin-top: 1rem; font-weight: 600; font-size: 0.92rem; }
      input {
        width: 100%;
        padding: 0.55rem 0.7rem;
        border: 1px solid #e2ded4;
        border-radius: 6px;
        font: inherit;
        margin-top: 0.3rem;
        box-sizing: border-box;
      }
      button {
        width: 100%;
        margin-top: 1.25rem;
        padding: 0.6rem 1rem;
        background: #1f6f6a;
        color: #fff;
        border: 0;
        border-radius: 6px;
        font: inherit;
        font-weight: 600;
        cursor: pointer;
      }
      button:hover { background: #175955; }
      button:disabled { opacity: 0.6; cursor: not-allowed; }
      .flash {
        padding: 0.6rem 0.8rem;
        border-radius: 6px;
        margin-top: 1rem;
        font-size: 0.92rem;
      }
      .flash-error {
        background: #fdecea;
        color: #7a2a20;
        border: 1px solid #f5c6c0;
      }
      .flash-success {
        background: #e8f5e9;
        color: #1a4e1c;
        border: 1px solid #c4e2c6;
      }
      .hint { font-size: 0.82rem; color: #6b6b6b; margin-top: 0.3rem; }
    </style>
  </head>
  <body>
    <div class="panel">
      <h1>Set your password</h1>
      <p class="muted">Choose a new password to access the admin.</p>

      <div id="loading" class="hint">Verifying link…</div>

      <form id="set-pw-form" hidden>
        <label for="password">New password</label>
        <input id="password" name="password" type="password" minlength="8" required autocomplete="new-password" />
        <div class="hint">At least 8 characters.</div>

        <label for="confirm">Confirm password</label>
        <input id="confirm" name="confirm" type="password" minlength="8" required autocomplete="new-password" />

        <button type="submit" id="submit-btn">Save password</button>
      </form>

      <div id="flash" class="flash" hidden></div>
    </div>

    <script>
      import { createBrowserClient } from '@supabase/ssr';

      const supabase = createBrowserClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
      );

      const loading = document.getElementById('loading') as HTMLElement;
      const form = document.getElementById('set-pw-form') as HTMLFormElement;
      const pw = document.getElementById('password') as HTMLInputElement;
      const confirm = document.getElementById('confirm') as HTMLInputElement;
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
      const flash = document.getElementById('flash') as HTMLElement;

      function showFlash(kind: 'success' | 'error', message: string) {
        flash.hidden = false;
        flash.className = `flash flash-${kind}`;
        flash.textContent = message;
      }

      async function waitForSession() {
        const { data } = await supabase.auth.getSession();
        if (data.session) return data.session;
        return await new Promise<null | typeof data.session>((resolve) => {
          const timer = setTimeout(() => {
            sub.subscription.unsubscribe();
            resolve(null);
          }, 4000);
          const sub = supabase.auth.onAuthStateChange((_event, session) => {
            if (session) {
              clearTimeout(timer);
              sub.subscription.unsubscribe();
              resolve(session);
            }
          });
        });
      }

      (async () => {
        const session = await waitForSession();
        loading.hidden = true;
        if (!session) {
          showFlash(
            'error',
            'This link is invalid or expired. Ask an admin to resend the invite or reset link.',
          );
          return;
        }
        form.hidden = false;
      })();

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        flash.hidden = true;
        if (pw.value !== confirm.value) {
          showFlash('error', 'Passwords do not match.');
          return;
        }
        submitBtn.disabled = true;
        const { error } = await supabase.auth.updateUser({ password: pw.value });
        if (error) {
          showFlash('error', error.message);
          submitBtn.disabled = false;
          return;
        }
        showFlash('success', 'Password saved. Redirecting…');
        setTimeout(() => {
          window.location.href = '/admin';
        }, 800);
      });
    </script>
  </body>
</html>
