---
import AdminLayout from '~/layouts/AdminLayout.astro';
import SettingsNav from '~/components/admin/SettingsNav.astro';
import ShippingSettingsForm from '~/components/admin/ShippingSettingsForm.astro';
import { createSupabaseAdminClient } from '~/lib/supabase/admin';

export const prerender = false;

const supabase = createSupabaseAdminClient();
const { data: settings, error } = await supabase
  .from('shipping_settings')
  .select('*')
  .eq('id', 1)
  .maybeSingle();
---

<AdminLayout title="Shipping settings">
  <div class="page-header">
    <h1>Shipping</h1>
  </div>

  <SettingsNav />

  {error && <div class="flash flash-error">{error.message}</div>}

  {
    settings ? (
      <div class="panel">
        <ShippingSettingsForm settings={settings} />
      </div>
    ) : (
      <div class="panel">
        <p class="muted">Shipping settings row not found. Run the latest migration.</p>
      </div>
    )
  }
</AdminLayout>
