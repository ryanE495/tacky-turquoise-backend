---
import { createSupabaseServerClient } from '~/lib/supabase/server';

export const prerender = false;

const supabase = createSupabaseServerClient({
  cookies: Astro.cookies,
  request: Astro.request,
});
const { data: existing } = await supabase.auth.getUser();

const next = Astro.url.searchParams.get('next') || '/admin';

if (existing.user) {
  return Astro.redirect(next);
}

let error: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = String(form.get('email') ?? '').trim();
  const password = String(form.get('password') ?? '');

  if (!email || !password) {
    error = 'Email and password are required';
  } else {
    const { error: signInErr } = await supabase.auth.signInWithPassword({ email, password });
    if (signInErr) {
      error = signInErr.message;
    } else {
      // 303 ensures browsers GET the redirect target after a POST. The
      // queued auth cookies set by Supabase via setAll() are attached to
      // this response by Astro automatically.
      return Astro.redirect(next, 303);
    }
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Admin Login</title>
    <style>
      body {
        margin: 0;
        background: #f7f6f2;
        color: #1a1a1a;
        font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 1rem;
      }
      .panel {
        background: #fff;
        border: 1px solid #e2ded4;
        border-radius: 8px;
        padding: 1.5rem;
        max-width: 380px;
        width: 100%;
      }
      h1 { margin: 0 0 0.25rem; font-size: 1.4rem; }
      .muted { color: #6b6b6b; }
      label { display: block; margin-top: 1rem; font-weight: 600; font-size: 0.92rem; }
      input {
        width: 100%;
        padding: 0.55rem 0.7rem;
        border: 1px solid #e2ded4;
        border-radius: 6px;
        font: inherit;
        font-size: 16px;
        margin-top: 0.3rem;
        box-sizing: border-box;
      }
      button {
        width: 100%;
        margin-top: 1.25rem;
        padding: 0.6rem 1rem;
        background: #1f6f6a;
        color: #fff;
        border: 0;
        border-radius: 6px;
        font: inherit;
        font-weight: 600;
        cursor: pointer;
      }
      button:hover { background: #175955; }
      button:disabled { opacity: 0.6; cursor: not-allowed; }
      .text-link {
        display: inline-block;
        margin-top: 0.9rem;
        background: transparent;
        border: 0;
        color: #1f6f6a;
        padding: 0;
        width: auto;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
      }
      .text-link:hover { background: transparent; text-decoration: underline; }
      .flash {
        padding: 0.55rem 0.75rem;
        border-radius: 6px;
        margin: 0.8rem 0 0;
        font-size: 0.9rem;
      }
      .flash-error {
        background: #fdecea;
        color: #7a2a20;
        border: 1px solid #f5c6c0;
      }
      .flash-success {
        background: #e8f5e9;
        color: #1a4e1c;
        border: 1px solid #c4e2c6;
      }
      .forgot {
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid #e2ded4;
      }
      .forgot h2 { font-size: 0.95rem; margin: 0 0 0.4rem; }
    </style>
  </head>
  <body>
    <div class="panel">
      <h1>Admin Login</h1>
      <p class="muted">Sign in to manage products.</p>

      {error && <div class="flash flash-error">{error}</div>}

      <form method="post" id="signin-form">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required autocomplete="username" />
        <label for="password">Password</label>
        <input id="password" name="password" type="password" required autocomplete="current-password" />
        <button type="submit" id="signin-btn">Sign in</button>
      </form>

      <button type="button" class="text-link" id="toggle-forgot">Forgot password?</button>

      <div class="forgot" id="forgot-wrap" hidden>
        <h2>Reset password</h2>
        <p class="muted" style="font-size: 0.88rem; margin: 0 0 0.5rem;">
          Enter the email tied to your admin account. We'll send a reset link.
        </p>
        <form id="forgot-form">
          <input id="forgot-email" name="email" type="email" required placeholder="you@example.com" />
          <button type="submit" id="forgot-submit">Send reset link</button>
        </form>
        <div id="forgot-flash" class="flash" hidden></div>
      </div>
    </div>

    <script>
      import { createBrowserClient } from '@supabase/ssr';

      // Disable the sign-in button on submit so a slow signin doesn't
      // invite double-clicks that race the cookie write.
      const signinForm = document.getElementById('signin-form') as HTMLFormElement;
      const signinBtn = document.getElementById('signin-btn') as HTMLButtonElement;
      signinForm.addEventListener('submit', () => {
        signinBtn.disabled = true;
        signinBtn.textContent = 'Signing in…';
      });

      const supabase = createBrowserClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
      );

      const toggle = document.getElementById('toggle-forgot') as HTMLButtonElement;
      const wrap = document.getElementById('forgot-wrap') as HTMLElement;
      const form = document.getElementById('forgot-form') as HTMLFormElement;
      const emailInput = document.getElementById('forgot-email') as HTMLInputElement;
      const submit = document.getElementById('forgot-submit') as HTMLButtonElement;
      const flash = document.getElementById('forgot-flash') as HTMLElement;

      toggle.addEventListener('click', () => {
        wrap.hidden = !wrap.hidden;
        if (!wrap.hidden) emailInput.focus();
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        flash.hidden = true;
        submit.disabled = true;
        const email = emailInput.value.trim();
        const { error } = await supabase.auth.resetPasswordForEmail(email, {
          redirectTo: `${window.location.origin}/admin/set-password`,
        });
        if (error) {
          flash.hidden = false;
          flash.className = 'flash flash-error';
          flash.textContent = error.message;
        } else {
          flash.hidden = false;
          flash.className = 'flash flash-success';
          flash.textContent = `If an account exists for ${email}, a reset link has been sent.`;
          emailInput.value = '';
        }
        submit.disabled = false;
      });
    </script>
  </body>
</html>
