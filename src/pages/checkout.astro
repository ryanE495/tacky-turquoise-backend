---
import SiteLayout from '~/layouts/SiteLayout.astro';
import UnavailableItemsBanner from '~/components/UnavailableItemsBanner.astro';
import { US_STATES } from '~/lib/orders';

export const prerender = false;
---

<SiteLayout title="Checkout · Tacky Turquoise">
  <h1>Checkout</h1>

  <UnavailableItemsBanner />

  <div id="checkout-loading" class="loading muted">Loading…</div>
  <div id="checkout-error" class="flash flash-error" hidden></div>

  <div class="checkout-grid" id="checkout-body" hidden>
    <section class="form-col">
      <form id="checkout-form" novalidate>
        <fieldset>
          <legend>Contact</legend>
          <div class="grid-2">
            <div class="field full">
              <label for="email">Email *</label>
              <input id="email" name="email" type="email" required autocomplete="email" />
            </div>
            <div class="field full">
              <label for="name">Full name *</label>
              <input id="name" name="name" type="text" required autocomplete="name" />
            </div>
            <div class="field full">
              <label for="phone">Phone <span class="muted">(optional)</span></label>
              <input id="phone" name="phone" type="tel" autocomplete="tel" />
            </div>
          </div>
        </fieldset>

        <fieldset>
          <legend>Shipping address</legend>
          <div class="grid-2">
            <div class="field full">
              <label for="line1">Address line 1 *</label>
              <input id="line1" name="line1" type="text" required autocomplete="address-line1" />
            </div>
            <div class="field full">
              <label for="line2">Address line 2 <span class="muted">(optional)</span></label>
              <input id="line2" name="line2" type="text" autocomplete="address-line2" />
            </div>
            <div class="field">
              <label for="city">City *</label>
              <input id="city" name="city" type="text" required autocomplete="address-level2" />
            </div>
            <div class="field">
              <label for="state">State *</label>
              <select id="state" name="state" required autocomplete="address-level1">
                <option value="">Select…</option>
                {US_STATES.map((s) => <option value={s.value}>{s.label}</option>)}
              </select>
            </div>
            <div class="field">
              <label for="postal_code">ZIP *</label>
              <input
                id="postal_code"
                name="postal_code"
                type="text"
                required
                inputmode="numeric"
                autocomplete="postal-code"
                pattern="\d{5}(-\d{4})?"
              />
            </div>
            <div class="field">
              <label for="country">Country</label>
              <input id="country" name="country" type="text" value="United States" disabled />
              <div class="hint muted">US shipping only for now.</div>
            </div>
          </div>
        </fieldset>

        <fieldset>
          <legend>Order notes <span class="muted">(optional)</span></legend>
          <textarea id="customer_notes" name="customer_notes" rows="3"></textarea>
        </fieldset>
      </form>
    </section>

    <aside class="summary-col">
      <div class="summary">
        <h2>Order summary</h2>
        <ul class="items" id="summary-items"></ul>
        <div class="totals">
          <div class="row">
            <span>Subtotal</span>
            <span class="amount" id="subtotal">—</span>
          </div>
          <div class="row" id="shipping-row">
            <span>Shipping</span>
            <span class="amount" id="shipping-display">Enter address to calculate</span>
          </div>
          <div class="row muted">
            <span>Tax</span>
            <span>Calculated at payment</span>
          </div>
          <div class="row total">
            <span>Estimated total</span>
            <span class="amount" id="total">—</span>
          </div>
        </div>
        <button type="button" id="complete-btn" class="btn btn-primary complete-btn" disabled>
          Complete order
        </button>
        <div class="redirect-note muted">You'll be redirected to secure payment.</div>
      </div>
    </aside>
  </div>
</SiteLayout>

<script>
  import { getCart, removeManyFromCart } from '~/lib/cart';
  import { formatPrice } from '~/lib/format';

  type Available = {
    id: string;
    slug: string;
    piece_id: string;
    title: string;
    price_cents: number;
    length: string | null;
    primary_image_url: string | null;
  };
  type Unavailable = {
    id: string;
    reason: 'sold' | 'archived' | 'draft' | 'not_found';
    title?: string;
    slug?: string;
  };
  type ShippingQuote = {
    rate_id: string;
    amount_cents: number;
    service_level: string;
    estimated_days: number;
    provider: string;
  };

  const loading = document.getElementById('checkout-loading') as HTMLElement;
  const errorEl = document.getElementById('checkout-error') as HTMLElement;
  const body = document.getElementById('checkout-body') as HTMLElement;
  const itemsEl = document.getElementById('summary-items') as HTMLUListElement;
  const subtotalEl = document.getElementById('subtotal') as HTMLElement;
  const shippingDisplay = document.getElementById('shipping-display') as HTMLElement;
  const shippingRow = document.getElementById('shipping-row') as HTMLElement;
  const totalEl = document.getElementById('total') as HTMLElement;
  const form = document.getElementById('checkout-form') as HTMLFormElement;
  const completeBtn = document.getElementById('complete-btn') as HTMLButtonElement;

  let currentCartIds: string[] = [];
  let currentItems: Available[] = [];
  let shippingQuote: ShippingQuote | null = null;
  let debounceTimer: number | null = null;
  let inflightController: AbortController | null = null;
  let quoteSeq = 0;

  function escapeAttr(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/"/g, '&quot;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }

  function renderSummary() {
    itemsEl.innerHTML = currentItems
      .map(
        (p) => `
      <li class="item">
        <div class="thumb">
          ${p.primary_image_url ? `<img src="${escapeAttr(p.primary_image_url)}" alt="${escapeAttr(p.title)}" />` : ''}
        </div>
        <div class="meta">
          <div class="title">${escapeAttr(p.title)}</div>
          <div class="muted piece-id">${escapeAttr(p.piece_id)}</div>
        </div>
        <div class="price">${formatPrice(p.price_cents)}</div>
      </li>`,
      )
      .join('');

    const subtotal = currentItems.reduce((sum, p) => sum + p.price_cents, 0);
    subtotalEl.textContent = formatPrice(subtotal);
    renderShippingLine();
  }

  function renderShippingLine() {
    const subtotal = currentItems.reduce((sum, p) => sum + p.price_cents, 0);
    shippingRow.classList.remove('flash-error');
    if (shippingQuote) {
      shippingDisplay.textContent = `${shippingQuote.service_level} (~${shippingQuote.estimated_days} days) — ${formatPrice(shippingQuote.amount_cents)}`;
      shippingDisplay.classList.remove('muted');
      totalEl.textContent = formatPrice(subtotal + shippingQuote.amount_cents);
      completeBtn.disabled = false;
    } else {
      totalEl.textContent = '—';
      completeBtn.disabled = true;
    }
  }

  function setShippingState(state: 'idle' | 'loading' | 'error', message?: string) {
    shippingRow.classList.remove('flash-error');
    switch (state) {
      case 'idle':
        shippingDisplay.textContent = message ?? 'Enter address to calculate';
        shippingDisplay.classList.add('muted');
        break;
      case 'loading':
        shippingDisplay.textContent = 'Calculating…';
        shippingDisplay.classList.add('muted');
        break;
      case 'error':
        shippingDisplay.textContent = message ?? 'Unable to calculate shipping.';
        shippingDisplay.classList.remove('muted');
        shippingRow.classList.add('flash-error');
        break;
    }
    totalEl.textContent = '—';
    completeBtn.disabled = true;
  }

  function showError(msg: string) {
    errorEl.hidden = false;
    errorEl.textContent = msg;
  }
  function clearError() {
    errorEl.hidden = true;
  }

  function getAddressFromForm() {
    const fd = new FormData(form);
    return {
      name: String(fd.get('name') ?? '').trim() || 'Recipient',
      street1: String(fd.get('line1') ?? '').trim(),
      street2: String(fd.get('line2') ?? '').trim() || undefined,
      city: String(fd.get('city') ?? '').trim(),
      state: String(fd.get('state') ?? '').trim(),
      zip: String(fd.get('postal_code') ?? '').trim(),
      country: 'US',
    };
  }

  function addressReadyForQuote(): boolean {
    const a = getAddressFromForm();
    return (
      !!a.street1 &&
      !!a.city &&
      !!a.state &&
      /^\d{5}(-\d{4})?$/.test(a.zip)
    );
  }

  async function fetchQuote() {
    if (!addressReadyForQuote()) {
      shippingQuote = null;
      setShippingState('idle');
      return;
    }

    shippingQuote = null;
    setShippingState('loading');

    if (inflightController) {
      inflightController.abort();
    }
    const controller = new AbortController();
    inflightController = controller;
    const seq = ++quoteSeq;

    try {
      const res = await fetch('/api/shipping/quote', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          product_ids: currentCartIds,
          shipping_address: getAddressFromForm(),
        }),
        signal: controller.signal,
      });
      const json = await res.json();
      if (seq !== quoteSeq) return; // a newer request started
      if (!json.ok) {
        if (json.error?.code === 'items_unavailable') {
          removeManyFromCart(
            (json.error.unavailable ?? []).map((u: Unavailable) => u.id),
          );
          window.location.href = '/cart?unavailable=1';
          return;
        }
        setShippingState('error', json.error?.message ?? 'Unable to calculate shipping.');
        return;
      }
      shippingQuote = json.data as ShippingQuote;
      renderShippingLine();
    } catch (err) {
      if ((err as DOMException)?.name === 'AbortError') return;
      setShippingState('error', "Couldn't reach the shipping service. Try again.");
    }
  }

  function scheduleQuote() {
    if (debounceTimer !== null) window.clearTimeout(debounceTimer);
    shippingQuote = null;
    setShippingState('loading');
    debounceTimer = window.setTimeout(() => {
      debounceTimer = null;
      fetchQuote();
    }, 500);
  }

  function wireAddressListeners() {
    const ids = ['name', 'line1', 'line2', 'city', 'state', 'postal_code'];
    for (const id of ids) {
      const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement;
      el.addEventListener('input', scheduleQuote);
      el.addEventListener('change', scheduleQuote);
    }
  }

  async function bootstrap() {
    const cart = getCart();
    if (cart.items.length === 0) {
      window.location.href = '/shop';
      return;
    }
    const res = await fetch('/api/cart/validate', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ product_ids: cart.items.map((i) => i.product_id) }),
    });
    const json = await res.json();
    if (!json.ok) {
      loading.hidden = true;
      showError(json.error || "We couldn't load your cart.");
      return;
    }
    const available: Available[] = json.data.available;
    const unavailable: Unavailable[] = json.data.unavailable;

    if (unavailable.length > 0) {
      removeManyFromCart(unavailable.map((u) => u.id));
      window.location.href = '/cart?unavailable=1';
      return;
    }
    if (available.length === 0) {
      window.location.href = '/shop';
      return;
    }

    currentCartIds = available.map((p) => p.id);
    currentItems = available;
    loading.hidden = true;
    body.hidden = false;
    renderSummary();
    wireAddressListeners();
  }

  function collectPayload() {
    const fd = new FormData(form);
    return {
      customer: {
        email: String(fd.get('email') ?? '').trim(),
        name: String(fd.get('name') ?? '').trim(),
        phone: String(fd.get('phone') ?? '').trim() || null,
      },
      shipping_address: {
        name: String(fd.get('name') ?? '').trim(),
        line1: String(fd.get('line1') ?? '').trim(),
        line2: String(fd.get('line2') ?? '').trim() || null,
        city: String(fd.get('city') ?? '').trim(),
        state: String(fd.get('state') ?? '').trim(),
        postal_code: String(fd.get('postal_code') ?? '').trim(),
        country: 'US',
      },
      customer_notes: String(fd.get('customer_notes') ?? '').trim() || null,
    };
  }

  function validatePayload(p: ReturnType<typeof collectPayload>): string | null {
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(p.customer.email)) return 'Valid email is required.';
    if (!p.customer.name) return 'Name is required.';
    if (!p.shipping_address.line1) return 'Address is required.';
    if (!p.shipping_address.city) return 'City is required.';
    if (!p.shipping_address.state) return 'State is required.';
    if (!/^\d{5}(-\d{4})?$/.test(p.shipping_address.postal_code)) return 'Valid ZIP is required.';
    return null;
  }

  completeBtn.addEventListener('click', async () => {
    clearError();
    if (!shippingQuote) {
      showError('Waiting for shipping quote…');
      return;
    }
    const payload = collectPayload();
    const valErr = validatePayload(payload);
    if (valErr) {
      showError(valErr);
      return;
    }

    completeBtn.disabled = true;
    completeBtn.textContent = 'Processing…';

    const res = await fetch('/api/checkout/create', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({
        product_ids: currentCartIds,
        shipping_rate_id: shippingQuote.rate_id,
        ...payload,
      }),
    });
    const json = await res.json();

    if (!json.ok) {
      if (json.error?.code === 'items_unavailable') {
        const slugs: string[] = (json.error.unavailable ?? [])
          .map((u: Unavailable) => u.slug)
          .filter(Boolean);
        removeManyFromCart((json.error.unavailable ?? []).map((u: Unavailable) => u.id));
        window.location.href = `/order/failed?reason=sold_out&items=${encodeURIComponent(slugs.join(','))}`;
        return;
      }
      showError(
        typeof json.error === 'string'
          ? json.error
          : json.error?.message ?? 'Checkout failed.',
      );
      completeBtn.disabled = false;
      completeBtn.textContent = 'Complete order';
      return;
    }

    window.location.href = json.data.redirect_to;
  });

  bootstrap();
</script>

<style>
  h1 {
    margin: 0 0 1rem;
    font-size: 1.6rem;
  }
  .loading {
    padding: 2rem 0;
    text-align: center;
  }
  .checkout-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1.5rem;
    align-items: start;
  }
  @media (min-width: 900px) {
    .checkout-grid {
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
      gap: 2.5rem;
    }
    .summary-col {
      position: sticky;
      top: 5rem;
    }
  }

  fieldset {
    border: 1px solid var(--site-border);
    border-radius: 8px;
    padding: 1rem 1.1rem 1.25rem;
    margin: 0 0 1rem;
    background: var(--site-panel);
  }
  legend {
    padding: 0 0.4rem;
    font-weight: 600;
  }
  .grid-2 {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 0.75rem;
  }
  .grid-2 .full {
    grid-column: 1 / -1;
  }
  @media (max-width: 520px) {
    .grid-2 {
      grid-template-columns: minmax(0, 1fr);
    }
  }
  .field {
    min-width: 0;
  }
  .hint {
    font-size: 0.82rem;
    margin-top: 0.3rem;
  }

  .summary {
    background: var(--site-panel);
    border: 1px solid var(--site-border);
    border-radius: 10px;
    padding: 1.1rem 1.15rem 1.25rem;
  }
  .summary h2 {
    margin: 0 0 0.8rem;
    font-size: 1.1rem;
  }
  .items {
    list-style: none;
    padding: 0;
    margin: 0 0 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .item {
    display: grid;
    grid-template-columns: 52px 1fr auto;
    gap: 0.6rem;
    align-items: center;
  }
  .item .thumb {
    width: 52px;
    height: 52px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--site-muted-bg);
  }
  .item .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .item .title {
    font-size: 0.92rem;
    font-weight: 500;
    line-height: 1.3;
  }
  .item .piece-id {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .item .price {
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    font-size: 0.92rem;
  }

  .totals {
    border-top: 1px solid var(--site-border);
    padding-top: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }
  .totals .row {
    display: flex;
    justify-content: space-between;
    font-size: 0.95rem;
    gap: 0.75rem;
  }
  .totals .row.total {
    font-weight: 700;
    font-size: 1.05rem;
    border-top: 1px solid var(--site-border);
    padding-top: 0.5rem;
    margin-top: 0.25rem;
  }
  .totals .row.flash-error {
    color: var(--site-danger);
  }
  .amount {
    font-variant-numeric: tabular-nums;
    text-align: right;
  }
  .complete-btn {
    width: 100%;
    padding: 0.9rem;
    font-size: 1rem;
    font-weight: 600;
  }
  .redirect-note {
    font-size: 0.8rem;
    text-align: center;
    margin-top: 0.55rem;
  }
</style>
