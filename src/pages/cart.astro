---
import SiteLayout from '~/layouts/SiteLayout.astro';
import UnavailableItemsBanner from '~/components/UnavailableItemsBanner.astro';

export const prerender = false;
---

<SiteLayout title="Your cart · Tacky Turquoise">
  <h1>Your cart</h1>

  <UnavailableItemsBanner />

  <div id="cart-loading" class="loading muted">Loading your cart…</div>

  <div id="cart-empty" class="empty" hidden>
    <p>Your cart is empty.</p>
    <a class="btn" href="/shop">Continue shopping</a>
  </div>

  <div id="cart-populated" hidden>
    <ul class="items" id="cart-items"></ul>

    <div class="totals">
      <div class="row">
        <span>Subtotal</span>
        <span class="amount" id="subtotal">—</span>
      </div>
      <div class="row muted">
        <span>Shipping</span>
        <span>Calculated at checkout</span>
      </div>
      <div class="row total">
        <span>Total</span>
        <span class="amount" id="total">—</span>
      </div>
    </div>

    <div class="actions">
      <a href="/checkout" class="btn btn-primary checkout-btn">Check out</a>
      <a href="/shop" class="continue">Continue shopping</a>
    </div>
  </div>
</SiteLayout>

<script>
  import { getCart, removeFromCart, removeManyFromCart, subscribeToCart } from '~/lib/cart';
  import { formatPrice } from '~/lib/format';

  type Available = {
    id: string;
    slug: string;
    piece_id: string;
    title: string;
    price_cents: number;
    length: string | null;
    primary_image_url: string | null;
  };
  type Unavailable = {
    id: string;
    reason: 'sold' | 'archived' | 'draft' | 'not_found';
    title?: string;
    slug?: string;
  };

  const loading = document.getElementById('cart-loading') as HTMLElement;
  const emptyEl = document.getElementById('cart-empty') as HTMLElement;
  const populated = document.getElementById('cart-populated') as HTMLElement;
  const itemsEl = document.getElementById('cart-items') as HTMLUListElement;
  const subtotalEl = document.getElementById('subtotal') as HTMLElement;
  const totalEl = document.getElementById('total') as HTMLElement;
  const banner = document.getElementById('unavailable-banner') as HTMLElement;

  function escapeAttr(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/"/g, '&quot;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }

  function showBanner(unavailable: Unavailable[]) {
    if (unavailable.length === 0) {
      banner.hidden = true;
      return;
    }
    const names = unavailable
      .map((u) => u.title || 'a piece')
      .join(', ');
    banner.hidden = false;
    banner.textContent = `Some pieces in your cart are no longer available and have been removed: ${names}.`;
  }

  function renderItems(items: Available[]) {
    itemsEl.innerHTML = items
      .map(
        (p) => `
        <li class="item" data-id="${p.id}">
          <a class="thumb" href="/product/${encodeURIComponent(p.slug)}">
            ${
              p.primary_image_url
                ? `<img src="${escapeAttr(p.primary_image_url)}" alt="${escapeAttr(p.title)}" />`
                : '<div class="thumb-empty muted">no image</div>'
            }
          </a>
          <div class="meta">
            <div class="title-line">
              <span class="piece-id muted">${escapeAttr(p.piece_id || '')}</span>
              <a class="title" href="/product/${encodeURIComponent(p.slug)}">${escapeAttr(p.title)}</a>
            </div>
            ${p.length ? `<div class="muted sub">${escapeAttr(p.length)}</div>` : ''}
            <button type="button" class="remove" data-remove="${p.id}">Remove</button>
          </div>
          <div class="price">${formatPrice(p.price_cents)}</div>
        </li>
      `,
      )
      .join('');
  }

  function renderTotals(items: Available[]) {
    const subtotal = items.reduce((sum, p) => sum + p.price_cents, 0);
    subtotalEl.textContent = formatPrice(subtotal);
    totalEl.textContent = formatPrice(subtotal);
  }

  async function validateAndRender() {
    const cart = getCart();
    loading.hidden = false;
    emptyEl.hidden = true;
    populated.hidden = true;

    if (cart.items.length === 0) {
      loading.hidden = true;
      emptyEl.hidden = false;
      banner.hidden = true;
      return;
    }

    let res: Response;
    try {
      res = await fetch('/api/cart/validate', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ product_ids: cart.items.map((i) => i.product_id) }),
      });
    } catch {
      loading.hidden = true;
      banner.hidden = false;
      banner.textContent = "We couldn't load your cart. Please refresh.";
      return;
    }

    const json = await res.json();
    if (!json.ok) {
      loading.hidden = true;
      banner.hidden = false;
      banner.textContent = json.error || "We couldn't load your cart.";
      return;
    }

    const available: Available[] = json.data.available;
    const unavailable: Unavailable[] = json.data.unavailable;

    if (unavailable.length > 0) {
      removeManyFromCart(unavailable.map((u) => u.id));
      showBanner(unavailable);
    } else {
      banner.hidden = true;
    }

    loading.hidden = true;

    if (available.length === 0) {
      emptyEl.hidden = false;
      return;
    }

    populated.hidden = false;
    renderItems(available);
    renderTotals(available);
  }

  itemsEl.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-remove]') as HTMLElement | null;
    if (!btn) return;
    const id = btn.dataset.remove!;
    removeFromCart(id);
  });

  // When redirected here from checkout after discovering unavailable items,
  // the ids have already been stripped from localStorage — surface a banner
  // so the user understands why their cart shrank.
  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.get('unavailable') === '1') {
    banner.hidden = false;
    banner.textContent =
      'Some pieces from your cart were no longer available and have been removed. Please review the updated cart below.';
  }

  validateAndRender();
  subscribeToCart(() => validateAndRender());
</script>

<style>
  h1 {
    margin: 0 0 1rem;
    font-size: 1.6rem;
  }
  .loading {
    padding: 2rem 0;
    text-align: center;
  }
  .empty {
    max-width: 440px;
    margin: 2rem auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .items {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .item {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: 0.9rem;
    align-items: center;
    padding: 0.75rem;
    background: var(--site-panel);
    border: 1px solid var(--site-border);
    border-radius: 8px;
  }
  .thumb {
    width: 80px;
    height: 80px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--site-muted-bg);
    display: block;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .thumb-empty {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    text-transform: uppercase;
  }
  .meta {
    min-width: 0;
  }
  .title-line {
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
    flex-wrap: wrap;
  }
  .title {
    font-weight: 600;
    color: inherit;
    text-decoration: none;
  }
  .title:hover {
    color: var(--site-accent);
  }
  .piece-id {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .sub {
    font-size: 0.85rem;
    margin-top: 0.1rem;
  }
  .remove {
    background: transparent;
    border: 0;
    padding: 0.35rem 0;
    color: var(--site-muted);
    cursor: pointer;
    font: inherit;
    font-size: 0.85rem;
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-top: 0.2rem;
  }
  .remove:hover {
    color: var(--site-danger);
  }
  .price {
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .totals {
    max-width: 420px;
    margin-left: auto;
    border-top: 1px solid var(--site-border);
    padding-top: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .totals .row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }
  .totals .row.total {
    font-weight: 700;
    font-size: 1.05rem;
    border-top: 1px solid var(--site-border);
    padding-top: 0.5rem;
    margin-top: 0.2rem;
  }
  .amount {
    font-variant-numeric: tabular-nums;
  }

  .actions {
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    align-items: stretch;
  }
  .checkout-btn {
    padding: 0.9rem 1.5rem;
    font-weight: 600;
    font-size: 1rem;
  }
  .continue {
    text-align: center;
    color: var(--site-muted);
    text-decoration: none;
    padding: 0.4rem;
  }
  .continue:hover {
    color: var(--site-accent);
  }

  @media (min-width: 640px) {
    .actions {
      flex-direction: row;
      justify-content: flex-end;
      align-items: center;
    }
    .checkout-btn {
      min-width: 220px;
    }
  }

  @media (max-width: 520px) {
    .item {
      grid-template-columns: 64px 1fr;
      row-gap: 0.4rem;
    }
    .thumb {
      width: 64px;
      height: 64px;
    }
    .price {
      grid-column: 1 / -1;
      text-align: right;
    }
  }
</style>
