---
import SiteLayout from '~/layouts/SiteLayout.astro';
import { createSupabaseAdminClient } from '~/lib/supabase/admin';
import { publicImageUrl } from '~/lib/images';
import { formatPrice } from '~/lib/format';

export const prerender = false;

const slug = Astro.params.slug;
if (!slug) return Astro.redirect('/shop');

const supabase = createSupabaseAdminClient();
const { data: product } = await supabase
  .from('products')
  .select(
    'id, slug, piece_id, title, description, price_cents, length, status, product_images(storage_path, alt_text, display_order)',
  )
  .eq('slug', slug)
  .in('status', ['published', 'sold'])
  .maybeSingle();

if (!product) return new Response('Not found', { status: 404 });

const images = ((product as any).product_images ?? [])
  .slice()
  .sort((a: any, b: any) => a.display_order - b.display_order)
  .map((img: any) => ({
    url: publicImageUrl(supabase, img.storage_path),
    alt: img.alt_text || product.title,
  }));
const primary = images[0] ?? null;
const additional = images.slice(1);

const isSold = product.status === 'sold';
---

<SiteLayout
  title={`${product.title} · Tacky Turquoise`}
  description={product.description ?? undefined}
>
  <div class="breadcrumb muted">
    <a href="/shop">Shop</a> / {product.title}
  </div>

  <div class="product">
    <div class="gallery">
      <div class="primary">
        {
          primary ? (
            <img src={primary.url} alt={primary.alt} />
          ) : (
            <div class="empty muted">No image</div>
          )
        }
        {isSold && <span class="sold-overlay">Sold</span>}
      </div>
      {
        additional.length > 0 && (
          <div class="thumbs">
            {additional.map((img) => (
              <div class="thumb">
                <img src={img.url} alt={img.alt} />
              </div>
            ))}
          </div>
        )
      }
    </div>

    <div class="info">
      {product.piece_id && <div class="piece-id muted">Piece {product.piece_id}</div>}
      <h1>{product.title}</h1>
      <div class="price">{formatPrice(product.price_cents)}</div>
      {product.length && <div class="length muted">Length: {product.length}</div>}

      <div class="cart-action" data-product-id={product.id} data-status={product.status}>
        <button
          type="button"
          class="btn btn-primary cart-btn"
          id="cart-btn"
          disabled={isSold}
        >
          {isSold ? 'Sold' : 'Add to cart'}
        </button>
        <span class="cart-flash muted" id="cart-flash" hidden></span>
      </div>

      {
        product.description && (
          <div class="description">{product.description}</div>
        )
      }
    </div>
  </div>
</SiteLayout>

<script>
  import { addToCart, isInCart, subscribeToCart } from '~/lib/cart';

  const container = document.querySelector('.cart-action') as HTMLElement;
  if (container) {
    const productId = container.dataset.productId!;
    const status = container.dataset.status!;
    const btn = document.getElementById('cart-btn') as HTMLButtonElement;
    const flash = document.getElementById('cart-flash') as HTMLElement;

    function renderState() {
      if (status === 'sold') {
        btn.textContent = 'Sold';
        btn.disabled = true;
        btn.classList.remove('btn-primary');
        return;
      }
      if (isInCart(productId)) {
        btn.textContent = 'In cart — view cart';
        btn.classList.remove('btn-primary');
        btn.onclick = () => (window.location.href = '/cart');
      } else {
        btn.textContent = 'Add to cart';
        btn.classList.add('btn-primary');
        btn.onclick = () => {
          addToCart(productId);
          flash.hidden = false;
          flash.textContent = 'Added.';
          setTimeout(() => {
            flash.hidden = true;
          }, 2000);
        };
      }
    }

    renderState();
    subscribeToCart(() => renderState());
  }
</script>

<style>
  .breadcrumb {
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }
  .breadcrumb a {
    color: inherit;
    text-decoration: none;
  }
  .breadcrumb a:hover {
    color: var(--site-accent);
  }

  .product {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 800px) {
    .product {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
      gap: 2.5rem;
      align-items: start;
    }
    .info {
      position: sticky;
      top: 5rem;
    }
  }

  .gallery {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .primary {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--site-muted-bg);
    border-radius: 10px;
    overflow: hidden;
  }
  .primary img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .empty {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sold-overlay {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--site-danger);
    color: #fff;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    font-size: 0.78rem;
  }
  .thumbs {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.5rem;
  }
  .thumb {
    aspect-ratio: 1 / 1;
    border-radius: 6px;
    overflow: hidden;
    background: var(--site-muted-bg);
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .piece-id {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  h1 {
    margin: 0;
    font-size: 1.6rem;
    line-height: 1.25;
  }
  .price {
    font-size: 1.25rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .length {
    font-size: 0.92rem;
  }
  .cart-action {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }
  .cart-btn {
    min-width: 200px;
    padding: 0.8rem 1.25rem;
    font-weight: 600;
  }
  .cart-flash {
    font-size: 0.9rem;
    color: var(--site-accent);
  }
  .description {
    margin-top: 0.75rem;
    white-space: pre-wrap;
    line-height: 1.6;
  }
</style>
