---
import SiteLayout from '~/layouts/SiteLayout.astro';

export const prerender = false;
---

<SiteLayout title="Order confirmed · Tacky Turquoise">
  <div class="wrap">
    <div id="loading" class="loading panel" hidden>
      <div class="spinner" aria-hidden="true"></div>
      <div class="muted" id="loading-text">Confirming your payment…</div>
    </div>

    <div id="cancelled" class="panel" hidden>
      <h1>Checkout cancelled</h1>
      <p class="muted">Your cart is saved — come back when you're ready.</p>
      <div class="actions">
        <a class="btn btn-primary" href="/cart">Return to cart</a>
        <a class="btn" href="/shop">Back to shop</a>
      </div>
    </div>

    <div id="not-found" class="panel" hidden>
      <h1>Order not found</h1>
      <p class="muted">We couldn't find that order. Try reloading, or head back to the shop.</p>
      <a class="btn btn-primary" href="/shop">Back to shop</a>
    </div>

    <div id="still-processing" class="panel" hidden>
      <h1>Your payment is still processing</h1>
      <p class="muted" id="processing-msg">
        You'll receive an email confirmation shortly. No need to refresh — we've got this.
      </p>
      <a class="btn" href="/shop">Continue shopping</a>
    </div>

    <div id="confirmed" class="panel" hidden>
      <div class="check" aria-hidden="true">✓</div>
      <h1 id="thank-you">Thank you.</h1>
      <p class="muted" id="order-line"></p>

      <ul class="items" id="items"></ul>

      <div class="totals">
        <div class="row"><span>Subtotal</span><span class="amount" id="subtotal">—</span></div>
        <div class="row"><span>Shipping</span><span class="amount" id="shipping">—</span></div>
        <div class="row" id="tax-row" hidden><span>Tax</span><span class="amount" id="tax">—</span></div>
        <div class="row total"><span>Total paid</span><span class="amount" id="total">—</span></div>
      </div>

      <div class="ship-to">
        <div class="label muted">Shipping to</div>
        <div id="ship-to"></div>
      </div>

      <p class="email-note muted" id="email-note"></p>
      <p class="delivery muted" id="delivery-note" hidden></p>

      <a class="btn" href="/shop">Continue shopping</a>
    </div>
  </div>
</SiteLayout>

<script>
  import { clearCart } from '~/lib/cart';
  import { formatPrice } from '~/lib/format';

  const params = new URLSearchParams(window.location.search);
  const sessionId = params.get('session_id')?.trim() || '';
  const wasCancelled = params.get('cancelled') === '1';

  const loading = document.getElementById('loading') as HTMLElement;
  const loadingText = document.getElementById('loading-text') as HTMLElement;
  const cancelled = document.getElementById('cancelled') as HTMLElement;
  const notFound = document.getElementById('not-found') as HTMLElement;
  const stillProcessing = document.getElementById('still-processing') as HTMLElement;
  const confirmed = document.getElementById('confirmed') as HTMLElement;
  const thankYou = document.getElementById('thank-you') as HTMLElement;
  const orderLine = document.getElementById('order-line') as HTMLElement;
  const itemsEl = document.getElementById('items') as HTMLUListElement;
  const subtotalEl = document.getElementById('subtotal') as HTMLElement;
  const shippingEl = document.getElementById('shipping') as HTMLElement;
  const taxRow = document.getElementById('tax-row') as HTMLElement;
  const taxEl = document.getElementById('tax') as HTMLElement;
  const totalEl = document.getElementById('total') as HTMLElement;
  const shipToEl = document.getElementById('ship-to') as HTMLElement;
  const emailNote = document.getElementById('email-note') as HTMLElement;
  const deliveryNote = document.getElementById('delivery-note') as HTMLElement;

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  type OrderPayload = {
    order_number: string;
    status: string;
    customer_email: string;
    customer_name: string;
    items: Array<{
      title: string;
      piece_id: string;
      price_cents: number;
      primary_image_url: string | null;
    }>;
    ship_to: {
      name: string;
      line1: string;
      line2: string | null;
      city: string;
      state: string;
      postal_code: string;
      country: string;
    };
    subtotal_cents: number;
    shipping_cents: number;
    tax_cents: number;
    total_cents: number;
    shipping_service_level: string | null;
    shipping_estimated_days: number | null;
  };

  async function fetchOrder(): Promise<OrderPayload | 'not_found' | 'error'> {
    try {
      const res = await fetch(
        `/api/orders/by-session?session_id=${encodeURIComponent(sessionId)}`,
      );
      if (res.status === 404) return 'not_found';
      if (!res.ok) return 'error';
      const json = await res.json();
      if (!json.ok) return 'not_found';
      return json.data as OrderPayload;
    } catch {
      return 'error';
    }
  }

  function renderConfirmed(o: OrderPayload) {
    loading.hidden = true;
    stillProcessing.hidden = true;

    const firstName = o.customer_name.split(/\s+/)[0] || 'there';
    thankYou.textContent = `Thank you, ${firstName}.`;
    orderLine.textContent = `Your order ${o.order_number} has been received.`;

    itemsEl.innerHTML = o.items
      .map(
        (it) => `
        <li class="item">
          <div class="thumb">${
            it.primary_image_url
              ? `<img src="${escapeHtml(it.primary_image_url)}" alt="${escapeHtml(it.title)}" />`
              : ''
          }</div>
          <div class="meta">
            <div class="title">${escapeHtml(it.title)}</div>
            <div class="muted piece-id">${escapeHtml(it.piece_id)}</div>
          </div>
          <div class="price">${formatPrice(it.price_cents)}</div>
        </li>
      `,
      )
      .join('');

    subtotalEl.textContent = formatPrice(o.subtotal_cents);
    shippingEl.textContent = formatPrice(o.shipping_cents);
    if (o.tax_cents > 0) {
      taxEl.textContent = formatPrice(o.tax_cents);
      taxRow.hidden = false;
    }
    totalEl.textContent = formatPrice(o.total_cents);

    const lines = [
      o.ship_to.name,
      o.ship_to.line1,
      o.ship_to.line2,
      `${o.ship_to.city}, ${o.ship_to.state} ${o.ship_to.postal_code}`,
      o.ship_to.country,
    ].filter(Boolean);
    shipToEl.innerHTML = lines.map((l) => escapeHtml(l as string)).join('<br>');

    emailNote.textContent = `We'll email you at ${o.customer_email} when it ships.`;

    if (o.shipping_service_level && o.shipping_estimated_days) {
      deliveryNote.textContent = `Estimated delivery: ${o.shipping_service_level}, ~${o.shipping_estimated_days} business days.`;
      deliveryNote.hidden = false;
    }

    confirmed.hidden = false;
    clearCart();
  }

  async function init() {
    if (wasCancelled) {
      cancelled.hidden = false;
      return;
    }
    if (!sessionId) {
      notFound.hidden = false;
      return;
    }

    loading.hidden = false;

    // Webhook race: poll every 2s, up to 30s, waiting for status to flip to paid.
    const startedAt = Date.now();
    const deadline = startedAt + 30_000;
    let attempt = 0;

    while (true) {
      attempt += 1;
      const result = await fetchOrder();
      if (result === 'not_found') {
        loading.hidden = true;
        notFound.hidden = false;
        return;
      }
      if (result === 'error') {
        // transient error — keep trying until deadline
        if (Date.now() >= deadline) {
          loading.hidden = true;
          stillProcessing.hidden = false;
          return;
        }
      } else if (result.status === 'paid') {
        renderConfirmed(result);
        return;
      } else if (result.status === 'failed' || result.status === 'cancelled') {
        loading.hidden = true;
        notFound.hidden = false;
        return;
      } else {
        if (attempt >= 3) {
          loadingText.textContent = 'Still confirming — hang on a moment…';
        }
        if (Date.now() >= deadline) {
          loading.hidden = true;
          stillProcessing.hidden = false;
          return;
        }
      }

      await new Promise((r) => setTimeout(r, 2000));
    }
  }

  init();
</script>

<style>
  .wrap {
    max-width: 640px;
    margin: 0 auto;
  }
  .panel {
    background: var(--site-panel);
    border: 1px solid var(--site-border);
    border-radius: 12px;
    padding: 1.75rem 1.5rem;
    text-align: center;
  }
  .loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    padding: 3rem 1.5rem;
  }
  .spinner {
    width: 32px;
    height: 32px;
    border: 3px solid var(--site-muted-bg);
    border-top-color: var(--site-accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  .check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--site-accent);
    color: #fff;
    border-radius: 50%;
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
  }
  h1 {
    margin: 0 0 0.35rem;
    font-size: 1.5rem;
  }
  .actions {
    display: flex;
    gap: 0.6rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1rem;
  }
  .items {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    text-align: left;
  }
  .item {
    display: grid;
    grid-template-columns: 52px 1fr auto;
    gap: 0.65rem;
    align-items: center;
    padding: 0.55rem;
    background: #fbfaf6;
    border: 1px solid var(--site-border);
    border-radius: 8px;
  }
  .thumb {
    width: 52px;
    height: 52px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--site-muted-bg);
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .meta .title {
    font-size: 0.92rem;
    font-weight: 500;
  }
  .piece-id {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .price {
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    font-size: 0.92rem;
  }
  .totals {
    border-top: 1px solid var(--site-border);
    padding-top: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-align: left;
    max-width: 280px;
    margin-left: auto;
  }
  .totals .row {
    display: flex;
    justify-content: space-between;
  }
  .totals .row.total {
    font-weight: 700;
    font-size: 1.05rem;
    border-top: 1px solid var(--site-border);
    padding-top: 0.4rem;
    margin-top: 0.2rem;
  }
  .amount {
    font-variant-numeric: tabular-nums;
  }
  .ship-to {
    text-align: left;
    margin: 1.25rem 0 0.75rem;
  }
  .ship-to .label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }
  .email-note,
  .delivery {
    font-size: 0.92rem;
    margin: 0.35rem 0;
  }
  .delivery {
    margin-bottom: 1.25rem;
  }
</style>
