---
import SiteLayout from '~/layouts/SiteLayout.astro';

export const prerender = false;
---

<SiteLayout title="One of your pieces just sold · Tacky Turquoise">
  <div class="wrap">
    <div class="panel">
      <h1>One of your pieces just sold</h1>
      <p>
        Someone else completed their purchase before yours went through. These are true
        one-of-a-kind pieces so this occasionally happens.
      </p>

      <ul class="items" id="items"></ul>

      <div class="actions">
        <a class="btn btn-primary" href="/cart">Return to cart</a>
        <a class="btn" href="/shop">Back to shop</a>
      </div>

      <p class="muted refund">
        If you were charged, your payment will be refunded within 5 business days.
      </p>
    </div>
  </div>
</SiteLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const itemsParam = params.get('items') || '';
  const slugs = itemsParam.split(',').map((s) => s.trim()).filter(Boolean);
  const listEl = document.getElementById('items') as HTMLUListElement;
  if (slugs.length) {
    listEl.innerHTML = slugs
      .map(
        (s) => `
          <li><a href="/product/${encodeURIComponent(s)}">/${s}</a></li>
        `,
      )
      .join('');
  } else {
    listEl.hidden = true;
  }
</script>

<style>
  .wrap {
    max-width: 560px;
    margin: 0 auto;
  }
  .panel {
    background: var(--site-panel);
    border: 1px solid var(--site-border);
    border-radius: 12px;
    padding: 1.75rem 1.5rem;
    text-align: center;
  }
  h1 {
    margin: 0 0 0.5rem;
    font-size: 1.35rem;
  }
  p {
    margin: 0 0 1rem;
    line-height: 1.55;
  }
  .items {
    list-style: none;
    padding: 0;
    margin: 1rem auto;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-align: left;
    max-width: 360px;
  }
  .items li {
    background: #fbfaf6;
    border: 1px solid var(--site-border);
    border-radius: 6px;
    padding: 0.5rem 0.75rem;
    font-size: 0.9rem;
  }
  .items a {
    color: inherit;
    text-decoration: none;
  }
  .items a:hover {
    color: var(--site-accent);
  }
  .actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 1.25rem 0 0.75rem;
  }
  @media (min-width: 520px) {
    .actions {
      flex-direction: row;
      justify-content: center;
    }
  }
  .refund {
    font-size: 0.82rem;
    margin: 1rem 0 0;
  }
</style>
