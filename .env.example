PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public site origin (used in Stripe success/cancel URLs, email links, etc.)
# Defaults to request origin if unset. Set to https://your-domain.com in prod.
PUBLIC_SITE_URL=http://localhost:4322

# Stripe
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Paste after creating the webhook endpoint in the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=

# Shippo (live USPS rates)
SHIPPO_API_KEY=shippo_test_...
